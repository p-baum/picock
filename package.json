      "!skills/misc/**",
      "!skills/personal/**"
    ]
  },
  "scripts": {
    "changeset": "changeset",
    "validate:skills": "node scripts/validate-skill-distribution.mjs",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.30.0"
  },
  "packageManager": "npm@10.9.4"
}
