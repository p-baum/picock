{
  "name": "mattpocock-skills",
  "version": "1.3.0",
  "private": true,
  "description": "Matt Pocock's agent skills for real engineering",
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mattpocock/skills"
  },
  "license": "MIT",
  "pi": {
    "skills": [
      "./skills",
      "!skills/deprecated/**",
